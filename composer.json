{
    "name": "ldraw-org/library",
    "type": "project",
    "description": "The LDraw.org Library",
    "keywords": [
        "framework",
        "laravel",
        "ldraw",
        "lego"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/ldraw-org/blade-mdi.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/ldraw-org/laravel-chartjs.git"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-zip": "*",
        "blade-ui-kit/blade-icons": "^1.9.1",
        "fico7489/laravel-pivot": "^3.0.3",
        "filament/filament": "^5.5.1",
        "filament/spatie-laravel-media-library-plugin": "^5.5.1",
        "http-interop/http-factory-guzzle": ">=1.2.1",
        "icehouse-ventures/laravel-chartjs": "dev-master",
        "lara-zeus/quantity": "^3.0.1",
        "laravel/framework": "^13.5",
        "laravel/horizon": "^5.45.6",
        "laravel/pulse": "^1.7.3",
        "laravel/tinker": "^3.0.2",
        "league/flysystem-aws-s3-v3": "^3.32",
        "livewire/livewire": "^4.2.4",
        "mailgun/mailgun-php": "^4.4",
        "markrogoyski/math-php": "^2.13",
        "panphp/pan": "^0.1.10",
        "postare/blade-mdi": "dev-master",
        "sentry/sentry-laravel": "^4.25",
        "spatie/image": "^3.9.4",
        "spatie/laravel-backup": "^10.2.1",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-permission": "^8.0",
        "spatie/laravel-settings": "^3.7.2",
        "spatie/temporary-directory": "^2.3.1",
        "staudenmeir/belongs-to-through": "^2.18",
        "staudenmeir/laravel-adjacency-list": "^1.26.1",
        "symfony/http-client": "^8.0.8",
        "symfony/mailgun-mailer": "^8.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2.6",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.6",
        "laravel/pint": "^1.29.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.6.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "spatie/pest-plugin-route-testing": "^1.1.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/library_helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
